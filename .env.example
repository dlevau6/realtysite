# --- Supabase ---
# From your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Spark API (Bridge Interactive / MLS IDX) ---
# Issued once the MLS board approves your application at sparkplatform.com
SPARK_ACCESS_TOKEN=
SPARK_OFFICE_ID=

# --- Cron protection ---
# Random secret string; must match the Authorization header Vercel Cron sends.
CRON_SECRET=

# --- Admin panel auth ---
# The password Eric enters to sign in at /admin/login
ADMIN_PASSWORD=
# Long random string used to HMAC-sign the admin session cookie.
# Generate one with: openssl rand -hex 32
ADMIN_SESSION_SECRET=
